{
  "name": "gui-web",
  "version": "1.0.0",
  "description": "OpenClaw Agent Web 管理界面",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "npm run dev:server & npm run dev",
    "build": "vue-tsc --noEmit && tsc -p server/tsconfig.json --noEmit && vite build",
    "build:only": "vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "typecheck": "vue-tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue}\" \"server/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue}\" \"server/**/*.ts\""
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/markdown-it": "^14.1.1",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "eslint": "^9.24.0",
    "eslint-plugin-vue": "^10.1.0",
    "prettier": "^3.5.3",
    "sass": "^1.97.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.0.0"
  }
}
